# OpenAI (server-side only)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_FEEDBACK_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_TIMEOUT_MS=30000

# Optional low-cost / fallback LLM providers for OpenAI-compatible chat completions
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1/chat/completions
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1/chat/completions
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1/chat/completions
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1/chat/completions
ANTHROPIC_API_KEY=
ANTHROPIC_OPENAI_COMPAT_BASE_URL=
GEMINI_API_KEY=
GEMINI_OPENAI_COMPAT_BASE_URL=
LOCAL_LLM_BASE_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_API_KEY=

# Runtime
NODE_ENV=development
API_PORT=4000
MAX_JSON_BODY_BYTES=10485760
MAX_AUDIO_BYTES=8388608
DB_FILE_PATH=.data/confidencebuilder-db.json
NEXT_PUBLIC_DEFAULT_USER_ID=user_001

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/confidencebuilder

# Authentication
AUTH_SECRET=replace_with_a_long_random_secret
ADMIN_API_TOKEN=replace_with_a_long_random_admin_token
ADMIN_UI_TOKEN=replace_with_a_long_random_admin_ui_token

# Storage Provider (S3-compatible example)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=your_bucket_name
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=your_storage_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_storage_secret_access_key

# App URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
